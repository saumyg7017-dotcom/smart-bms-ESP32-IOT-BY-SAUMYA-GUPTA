void lcdS2() {
  lcd.setCursor(0,0); lcd.print("Health:         ");
  lcd.setCursor(0,1); lcd.print(healthStr()); lcd.print("          ");
}
void lcdS3() {
  lcd.setCursor(0,0);
  lcd.print("Relay:"); lcd.print(relayState?"ON ":"OFF");
  lcd.print(" "); lcd.print(modeStr().substring(0,5));
  lcd.setCursor(0,1);
  lcd.print("Fault:"); lcd.print(safetyFaultReason.substring(0,10));
}
void lcdFault() {
  lcd.setCursor(0,0); lcd.print("!!FAULT ACTIVE!!");
  lcd.setCursor(0,1); lcd.print(safetyFaultReason.substring(0,16));
}

void updateLCD() {
  if (safetyFaultActive) { lcdFault(); return; }
  unsigned long now = millis();
  if ((now - lastScreenChange) >= LCD_ROTATE_MS) {
    lcd.clear();
    currentScreen = (currentScreen + 1) % LCD_SCREEN_COUNT;
    lastScreenChange = now;
  }
  switch (currentScreen) {
    case 0: lcdS0(); break;
    case 1: lcdS1(); break;
    case 2: lcdS2(); break;
    case 3: lcdS3(); break;
  }
}

// ============================================================
//  TASK 4 — FAULT TOLERANT RUNTIME
// ============================================================
void logFault(String d) {
  faultLog[faultLogIndex] = {millis()/1000, d};
  faultLogIndex = (faultLogIndex + 1) % FAULT_LOG_SIZE;
  if (faultLogCount < FAULT_LOG_SIZE) faultLogCount++;
}

void updateSystemMode() {
  if (abs(battery.packAverage - lastPackAvg) < 0.001) frozenCount++;
  else frozenCount = 0;
  lastPackAvg = battery.packAverage;

  bool adcFrozen  = (frozenCount >= FROZEN_LIMIT);
  bool critFault  = (battery.healthState == PACK_FAILURE);
  bool minorFault = (battery.healthState == CRITICAL_IMBALANCE);

  if (adcFrozen) {
    if (systemMode != MODE_SHUTDOWN) logFault("ADC Frozen");
    systemMode = MODE_SHUTDOWN;
  } else if (critFault) {
    if (systemMode == MODE_NORMAL) logFault("Pack Failure");
    systemMode = MODE_FAILSAFE;
  } else if (minorFault) {
    if (systemMode == MODE_NORMAL) logFault("Crit Imbalance");
    systemMode = MODE_DEGRADED;
  } else {
    if (systemMode == MODE_FAILSAFE) systemMode = MODE_DEGRADED;
    else if (systemMode == MODE_DEGRADED) systemMode = MODE_NORMAL;
  }
}

// ============================================================
//  TASK 5 — CLOUD TELEMETRY
// ============================================================
void sendToBlynk() {
  if (!Blynk.connected()) { pendingTelemetry = true; return; }
  Blynk.virtualWrite(V0, battery.packAverage);
  Blynk.virtualWrite(V1, battery.cellVoltage[0]);
  Blynk.virtualWrite(V2, battery.cellVoltage[1]);
  Blynk.virtualWrite(V3, battery.cellVoltage[2]);
  Blynk.virtualWrite(V4, battery.cellVoltage[3]);
  Blynk.virtualWrite(V5, battery.healthPct);
  Blynk.virtualWrite(V6, healthStr());
  Blynk.virtualWrite(V7, safetyFaultReason);
  pendingTelemetry = false;
  Serial.println("[Blynk] Data sent");
}

void handleTelemetry() {
  unsigned long now = millis();
  if (!Blynk.connected()) {
    if ((now - lastWifiAttempt) >= WIFI_RETRY_MS) {
      lastWifiAttempt = now;
      Blynk.connect(3000);
    }
    return;
  }
  bool changed   = (battery.healthState != lastHealthState ||
                    systemMode != lastSysMode ||
                    relayState != lastRelayState ||
                    abs(battery.packAverage - lastAvgVoltage) > 0.05);
  bool force     = ((now - lastForcedSend) >= TELEMETRY_FORCE_MS);
  bool violation = (battery.packAverage < V_LOW ||
                    battery.packAverage > V_NORMAL_HIGH ||
                    battery.imbalancePct > 5.0);

  if (changed || force || violation || pendingTelemetry) {
    sendToBlynk();
    lastHealthState = battery.healthState;
    lastSysMode     = systemMode;
    lastRelayState  = relayState;
    lastAvgVoltage  = battery.packAverage;
    lastForcedSend  = now;
  }
}

// ============================================================
//  TASK 6 — EXECUTIVE DASHBOARD
// ============================================================
void printDashboard() {
  unsigned long now = millis();
  if ((now - lastDashPrint) < DASHBOARD_PRINT_MS) return;
  lastDashPrint = now;

  Serial.println("================================================");
  Serial.println("      SMART BMS - EXECUTIVE DASHBOARD          ");
  Serial.println("================================================");
  for (int i = 0; i < NUM_CELLS; i++) {
    Serial.printf("  Cell %d: %.2fV", i+1, battery.cellVoltage[i]);
    if ((i+1)==battery.weakestCell)   Serial.print(" <<WEAKEST");
    if ((i+1)==battery.strongestCell) Serial.print(" <<STRONGEST");
    Serial.println();
  }
  Serial.printf("  Avg: %.2fV | Imbalance: %.1f%% | Health: %.0f%%\n",
    battery.packAverage, battery.imbalancePct, battery.healthPct);
  Serial.printf("  State: %s | Mode: %s\n", healthStr().c_str(), modeStr().c_str());
  Serial.printf("  Relay: %s | Fault: %s\n",
    relayState?"CLOSED":"OPEN", safetyFaultReason.c_str());
  Serial.println("--- FAULT LOG ---");
  if (faultLogCount == 0) Serial.println("  No faults.");
  for (int i = 0; i < faultLogCount; i++)
    Serial.printf("  [%lus] %s\n", faultLog[i].timestamp, faultLog[i].description.c_str());
  Serial.println("--- RECOMMENDATION ---");
  switch (battery.healthState) {
    case HEALTHY:            Serial.println("  System OK. No action needed."); break;
    case MINOR_IMBALANCE:    Serial.println("  Monitor imbalance. Consider balancing."); break;
    case CRITICAL_IMBALANCE: Serial.println("  WARNING: Balance pack immediately!"); break;
    case PACK_FAILURE:       Serial.println("  CRITICAL: Replace weakest cell NOW!"); break;
  }
  Serial.println("================================================\n");
}

// ============================================================
//  SETUP
// ============================================================
void setup() {
  Serial.begin(115200);
  delay(500);

  pinMode(LED_RED,    OUTPUT);
  pinMode(LED_GREEN,  OUTPUT);
  pinMode(LED_YELLOW, OUTPUT);
  pinMode(BUZZER_PIN, OUTPUT);
  pinMode(RELAY_PIN,  OUTPUT);

  digitalWrite(LED_RED,    LOW);
  digitalWrite(LED_GREEN,  HIGH);  // Start green = normal
  digitalWrite(LED_YELLOW, LOW);
  digitalWrite(BUZZER_PIN, LOW);
  digitalWrite(RELAY_PIN,  HIGH);  // Relay closed by default

  analogReadResolution(12);

  Wire.begin(21, 22);
  lcd.init();
  lcd.backlight();
  lcd.setCursor(0, 0); lcd.print("  Smart BMS     ");
  lcd.setCursor(0, 1); lcd.print(" Initializing.. ");
  delay(2000);
  lcd.clear();

  Serial.println("[BMS] Connecting to Blynk...");
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
  Serial.println("[BMS] System Ready!");
  lcd.setCursor(0, 0); lcd.print("  BMS Online!   ");
  lcd.setCursor(0, 1); lcd.print(" Twist pots now ");
  delay(1000);
  lcd.clear();
}

// ============================================================
//  LOOP
// ============================================================
void loop() {
  updateBatteryIntelligence();  // TASK 1
  updateSystemMode();           // TASK 4
  runSafetyKernel();            // TASK 2
  updateLCD();                  // TASK 3
  handleTelemetry();            // TASK 5
  printDashboard();             // TASK 6
  Blynk.run();
  delay(100);
}
