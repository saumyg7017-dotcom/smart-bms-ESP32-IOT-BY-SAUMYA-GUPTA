bool            buzzerState       = false;
bool            safetyFaultActive = false;
String          safetyFaultReason = "None";
ProtectionEvent currentProtection = NO_FAULT;
SystemMode      systemMode        = MODE_NORMAL;

unsigned long lastRelayChange  = 0;
unsigned long lastBuzzerToggle = 0;
unsigned long lastScreenChange = 0;
unsigned long lastForcedSend   = 0;
unsigned long lastWifiAttempt  = 0;
unsigned long lastDashPrint    = 0;

int   currentScreen  = 0;
float lastPackAvg    = -1;
int   frozenCount    = 0;

float voltageHistory[5] = {3.7, 3.7, 3.7, 3.7, 3.7};
int   historyIndex      = 0;

bool  pendingTelemetry = false;
HealthState lastHealthState = HEALTHY;
SystemMode  lastSysMode     = MODE_NORMAL;
bool        lastRelayState  = true;
float       lastAvgVoltage  = 0;

