String healthStr() {
  switch (battery.healthState) {
    case HEALTHY:            return "HEALTHY";
    case MINOR_IMBALANCE:    return "MINOR IMBAL";
    case CRITICAL_IMBALANCE: return "CRIT IMBAL";
    case PACK_FAILURE:       return "PACK FAIL";
    default:                 return "UNKNOWN";
  }
}
String modeStr() {
  switch (systemMode) {
    case MODE_NORMAL:   return "NORMAL";
    case MODE_DEGRADED: return "DEGRADED";
    case MODE_FAILSAFE: return "FAILSAFE";
    case MODE_SHUTDOWN: return "SHUTDOWN";
    default:            return "UNKNOWN";
  }
}

// ============================================================
//  TASK 1 — BATTERY INTELLIGENCE ENGINE
// ============================================================
float readCell(int pin) {
  int raw = analogRead(pin);
  float v = (raw / (float)ADC_MAX) * V_SCALE;
  // In Wokwi, pot at zero = 0V. Map 0V reads to 3.5V default
  // so simulation starts in NORMAL state
  if (v < 0.1) v = 3.5;
  return v;
}

void updateBatteryIntelligence() {
  int pins[NUM_CELLS] = {CELL1_PIN, CELL2_PIN, CELL3_PIN, CELL4_PIN};
  float sum = 0;
  float minV = 999, maxV = 0;
  int   minIdx = 0, maxIdx = 0;

  for (int i = 0; i < NUM_CELLS; i++) {
    battery.cellVoltage[i] = readCell(pins[i]);
    sum += battery.cellVoltage[i];
    if (battery.cellVoltage[i] < minV) { minV = battery.cellVoltage[i]; minIdx = i; }
    if (battery.cellVoltage[i] > maxV) { maxV = battery.cellVoltage[i]; maxIdx = i; }
  }

  battery.packAverage   = sum / NUM_CELLS;
  battery.minCellV      = minV;
  battery.maxCellV      = maxV;
  battery.weakestCell   = minIdx + 1;
  battery.strongestCell = maxIdx + 1;

  float spread = maxV - minV;
  battery.imbalancePct = (battery.packAverage > 0)
                         ? (spread / battery.packAverage) * 100.0 : 0;

  float pct = ((battery.packAverage - V_LOW) / (V_SCALE - V_LOW)) * 100.0;
  battery.healthPct = constrain(pct, 0, 100);

  if      (battery.minCellV < V_MIN)    battery.healthState = PACK_FAILURE;
  else if (battery.imbalancePct > 10.0) battery.healthState = CRITICAL_IMBALANCE;
  else if (battery.imbalancePct > 5.0)  battery.healthState = MINOR_IMBALANCE;
  else                                  battery.healthState = HEALTHY;
}

// ============================================================
//  TASK 2 — SAFETY PROTECTION KERNEL
// ============================================================
void updateVoltageHistory(float v) {
  voltageHistory[historyIndex] = v;
  historyIndex = (historyIndex + 1) % 5;
}

bool detectRapidFluctuation() {
  float mn = 999, mx = 0;
  for (int i = 0; i < 5; i++) {
    if (voltageHistory[i] < mn) mn = voltageHistory[i];
    if (voltageHistory[i] > mx) mx = voltageHistory[i];
  }
  return (mx - mn) > 0.5;
}

ProtectionEvent evaluateSafety() {
  if (battery.minCellV < V_MIN)    return UNDERVOLTAGE;
  if (battery.maxCellV > V_SCALE)  return OVERVOLTAGE;
  if (battery.imbalancePct > 10.0) return WEAK_CELL;
  if (detectRapidFluctuation())    return RAPID_FLUCTUATION;
  return NO_FAULT;
}

void setRelay(bool closed) {
  unsigned long now = millis();
  if ((now - lastRelayChange) < RELAY_CHATTER_DELAY) return;
  if (relayState == closed) return;
  relayState = closed;
  digitalWrite(RELAY_PIN, closed ? HIGH : LOW);
  lastRelayChange = now;
}

void updateBuzzer(bool on) {
  unsigned long now = millis();
  if (!on) { digitalWrite(BUZZER_PIN, LOW); buzzerState = false; return; }
  unsigned long intv = buzzerState ? BUZZER_ON_TIME : BUZZER_OFF_TIME;
  if ((now - lastBuzzerToggle) >= intv) {
    buzzerState = !buzzerState;
    digitalWrite(BUZZER_PIN, buzzerState ? HIGH : LOW);
    lastBuzzerToggle = now;
  }
}

void runSafetyKernel() {
  updateVoltageHistory(battery.packAverage);
  currentProtection = evaluateSafety();
  safetyFaultActive = (currentProtection != NO_FAULT);

  switch (currentProtection) {
    case NO_FAULT:
      safetyFaultReason = "None";
      setRelay(true); updateBuzzer(false);
      digitalWrite(LED_GREEN, HIGH);
      digitalWrite(LED_RED,   LOW);
      digitalWrite(LED_YELLOW,LOW);
      break;
    case UNDERVOLTAGE:
      safetyFaultReason = "Undervoltage";
      setRelay(false); updateBuzzer(true);
      digitalWrite(LED_RED,   HIGH);
      digitalWrite(LED_GREEN, LOW);
      digitalWrite(LED_YELLOW,LOW);
      break;
    case OVERVOLTAGE:
      safetyFaultReason = "Overvoltage";
      setRelay(false); updateBuzzer(true);
      digitalWrite(LED_YELLOW,HIGH);
      digitalWrite(LED_GREEN, LOW);
      digitalWrite(LED_RED,   LOW);
      break;
    case WEAK_CELL:
      safetyFaultReason = "Weak Cell";
      setRelay(false); updateBuzzer(true);
      digitalWrite(LED_RED,   HIGH);
      digitalWrite(LED_GREEN, LOW);
      digitalWrite(LED_YELLOW,LOW);
      break;
    case RAPID_FLUCTUATION:
      safetyFaultReason = "Fluctuation";
      updateBuzzer(true);
      digitalWrite(LED_YELLOW,HIGH);
      digitalWrite(LED_GREEN, LOW);
      break;
    default:
      safetyFaultReason = "Unknown";
      break;
  }
}

