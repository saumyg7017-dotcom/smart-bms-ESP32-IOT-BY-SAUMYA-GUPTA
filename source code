// ============================================================
enum HealthState {
  HEALTHY, MINOR_IMBALANCE, CRITICAL_IMBALANCE, PACK_FAILURE
};
enum ProtectionEvent {
  NO_FAULT, WEAK_CELL, OVERVOLTAGE, UNDERVOLTAGE, SENSOR_ANOMALY, RAPID_FLUCTUATION
};
