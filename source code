}
void lcdS1() {
  lcd.setCursor(0,0);
  lcd.print("Avg:"); lcd.print(battery.packAverage,2);
  lcd.print("V "); lcd.print((int)battery.healthPct); lcd.print("%");
  lcd.setCursor(0,1);
  lcd.print("Imb:"); lcd.print(battery.imbalancePct,1);
  lcd.print("% W:C"); lcd.print(battery.weakestCell);
