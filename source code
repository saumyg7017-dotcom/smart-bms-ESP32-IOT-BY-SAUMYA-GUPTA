  MODE_NORMAL, MODE_DEGRADED, MODE_FAILSAFE, MODE_SHUTDOWN
};

// ============================================================
//  CONSTANTS
// ============================================================
#define NUM_CELLS            4
#define ADC_MAX              4095
#define V_SCALE              4.2
#define V_MIN                2.5
#define V_LOW                3.0
#define V_NORMAL_HIGH        4.0
#define RELAY_CHATTER_DELAY  2000
#define BUZZER_ON_TIME       200
#define BUZZER_OFF_TIME      300
#define LCD_SCREEN_COUNT     4
#define LCD_ROTATE_MS        3000
#define WIFI_RETRY_MS        10000
#define TELEMETRY_FORCE_MS   30000
#define DASHBOARD_PRINT_MS   5000
#define FROZEN_LIMIT         20
